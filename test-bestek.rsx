            <versie.informatie>
              <versie.eigen.tekst />
            </versie.informatie>
            <hoofdcode.hoofdtekst>
              <hoofdcode.vrijetekst>Communicatie met bewoners.</hoofdcode.vrijetekst>
            </hoofdcode.hoofdtekst>
            <hoofdcode.tekstblok>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>De aannemer verzorgt de communicatie met de bewoners, bestaande uit minimaal:</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>- afleggen van minimaal 1 huisbezoek t.b.v. voorlichting, toestemming, planning en afspraken over opruimwerkzaamheden</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>- opstellen van een standaard formulier van aanwezigheid en akkoord boven benoemde onderdelen</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>- per eigenaar een akkoordverklaring opstellen en ondertekenen.</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>- verkrijgen van een akkoordverklaring, voorzien van een handtekening van de betreffende eigenaar.</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>Hierop alle afspraken, planning, aanpak en opruimwerkzaamheden vermelden.</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>De aannemer rapporteert en overlegt met de directie.</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
              <alinea.hoofdcode>
                <hoofdcode.vrijetekst>Een en ander conform deel 3, 01.23.02 van dit bestek en EMVI-aspect A.</hoofdcode.vrijetekst>
              </alinea.hoofdcode>
            </hoofdcode.tekstblok>
          </dl22.bpost.6cijfer.0>
