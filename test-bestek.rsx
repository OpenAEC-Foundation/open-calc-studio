<?xml version="1.0" encoding="utf-8"?>
<raw.bestek xsi:noNamespaceSchemaLocation="RAWSX.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <raw.contractinfo tabposities="L125">
